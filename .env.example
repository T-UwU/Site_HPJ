# ────────────────────────────────────────────────────────────────
# Hotel Palacio Julio · variables de entorno
# ────────────────────────────────────────────────────────────────
# Copia este archivo a .env y rellena con los valores de tu proyecto.
# Si no defines estas variables, la app funciona en modo demo offline
# (selector de roles, sin servidor, datos en localStorage).
#
# Obtén estos valores en: Supabase Dashboard · Settings · API
# ────────────────────────────────────────────────────────────────

# URL del proyecto (Project URL)
VITE_SUPABASE_URL=https://tuproyecto.supabase.co

# Anon (public) key — esta es la que va en el frontend
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...
